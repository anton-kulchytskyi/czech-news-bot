# Скопіюй у .env (локально) або вистав ці змінні в Railway -> Variables

# Токен від @BotFather
TELEGRAM_TOKEN=

# Числовий id чату / каналу / групи (для каналу: -100xxxxxxxxxx)
TELEGRAM_CHAT_ID=

# Ключ з console.anthropic.com
ANTHROPIC_API_KEY=

# true = надіслати дайджест одразу при запуску (для тесту), інакше лише за розкладом
SEND_ON_START=
